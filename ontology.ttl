#################################################################
#    Individuals
#################################################################

###  http://example.com/secuman/ontology#Availability
:Availability rdf:type owl:NamedIndividual , :ProtectionGoal ;
                             rdfs:label "Availability" .



###  http://example.com/secuman/ontology#Confidentiality
:Confidentiality rdf:type owl:NamedIndividual , :ProtectionGoal ;
                             rdfs:label "Confidentiality" .


###  http://example.com/secuman/ontology#Integrity
:Integrity rdf:type owl:NamedIndividual , :ProtectionGoal ;
                          rdfs:label "Integrity" .



#################################################################
#    Disjointness
#################################################################


[ rdf:type owl:AllDisjointClasses ;
  owl:members (
    :Assumption
    :Assurance
    :Asset
    :AttackType
    :AttackerProfile
    :Component
    :ContextSpecificThreat
    :DataSecurityAndPrivacy
    :IdentityAndAccessManagement
    :ImpactAssessment
    :ImpactAssessmentDomain
    :ImpactLevel
    :ImplementationManifest
    :InterventionMethod
    :LikelihoodFactor
    :LocationOfIntervention
    :NetworkSecurity
    :OperatingEnvironment
    :OperationsAndMaintenance
    :OrganisationalContextOfIntervention
    :PhysicalSecurity
    :Product
    :ProtectionGoal
    :Rationale
    :SecurityRisk
    :SecurityRiskLevel
    :Strategy
    :SystemAndPlatformSecurity
    :TestReport
    :VulnerabilityLevel
  )
] .


:AnalyzedSecurityRisk owl:disjointWith :ControlledSecurityRisk .

:Impact owl:disjointWith :SecDA .


