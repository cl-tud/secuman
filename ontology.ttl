### http://example.com/secuman/ontology#AssuranceSecDA
:AssuranceSecDA rdf:type owl:Class ;
              rdfs:subClassOf :SecDA ;
              rdfs:label "Assurance SecDA" ;
              rdfs:comment "A secure design argument (SecDA), where the purpose is to make a security assurance" .

[ owl:intersectionOf ( :SecDA
                        [ rdf:type owl:Restriction ;
                            owl:onProperty :hasAssurance ;
                            owl:someValuesFrom owl:Thing
                        ] );                     
] rdfs:subClassOf :AssuranceSecDA .

### http://example.com/secuman/ontology#AssuranceSecDAI
:AssuranceSecDAI rdf:type owl:Class ;
    rdfs:comment "Assurance SecDAI having an implementation manifest" ;
    rdfs:label "Assurance SecDAI" .

[ owl:intersectionOf (  :AssuranceSecDA
                        :SecDAI
                     ) ;
] rdfs:subClassOf :AssuranceSecDAI .

### http://example.com/secuman/ontology#SecDA
:SecDA rdf:type owl:Class ;
  rdfs:label "SecDA" ;
  rdfs:comment "Secure design argument." .

[ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                            owl:onProperty :hasSafetyImpactAssessment;
                            owl:someValuesFrom owl:Thing
                        ]
                        [ rdf:type owl:Restriction ;
                            owl:onProperty :hasSecurityImpactAssessment;
                            owl:someValuesFrom owl:Thing
                        ]
                        [ rdf:type owl:Restriction ;
                            owl:onProperty :hasStrategy;
                            owl:someValuesFrom owl:Thing
                        ] ) ;
] rdfs:subClassOf :SecDA.

### http://example.com/secuman/ontology#SecDAI
:SecDAI rdf:type owl:Class ;
      rdfs:comment "Reusable artifact embodying or expressing one possible method or approach to risk control." ;
      rdfs:label "SecDAI" .   

[ owl:intersectionOf ( :SecDA
                        [ rdf:type owl:Restriction ;
                            owl:onProperty :hasImplementationManifest ;
                            owl:someValuesFrom owl:Thing
                        ]
                    )         
] rdfs:subClassOf :SecDAI .
  
  

