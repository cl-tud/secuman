#################################################################
#    Classes
#################################################################


### General


###  http://example.com/secuman/ontology#LikelihoodFactor
:LikelihoodFactor rdf:type owl:Class ;
    rdfs:label "Likelihood factor" ;
    rdfs:comment "Likelihood factor: attacker profile, vulnerability level" .

[ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                            owl:onProperty :hasAttackerProfile;
                            owl:someValuesFrom owl:Thing
                        ]
                        [ rdf:type owl:Restriction ;
                            owl:onProperty :hasVulnerabilityLevel;
                            owl:someValuesFrom owl:Thing
                        ] ) ;
] rdfs:subClassOf :LikelihoodFactor.

###  http://example.com/secuman/ontology#SecurityRisk
:SecurityRisk rdf:type owl:Class ;
    rdfs:label "Security risk" ;
    rdfs:comment "Security risk: security risk level" .

[ rdf:type owl:Restriction ;
    owl:onProperty :hasSecurityRiskLevel ;
    owl:someValuesFrom owl:Thing
] rdfs:subClassOf :SecurityRisk .





###  http://example.com/secuman/ontology#SecurityRiskLevel
:SecurityRiskLevel rdf:type owl:Class ;
    rdfs:label "Security risk level" ;
    rdfs:comment "Security risk level: impact level, likelihood factor" .

[ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                            owl:onProperty :hasImpactLevel;
                            owl:someValuesFrom owl:Thing
                        ]
                        [ rdf:type owl:Restriction ;
                            owl:onProperty :hasLikelihoodFactor;
                            owl:someValuesFrom owl:Thing
                        ] ) ;
] rdfs:subClassOf :SecurityRiskLevel.



###  http://example.com/secuman/ontology#ImpactAssessment
:ImpactAssessment rdf:type owl:Class ;
    rdfs:label "Impact assessment" ;
    rdfs:comment "Impact assessment: is affected" .

[ rdf:type owl:Restriction ;
    owl:onProperty :isAffected ;
    owl:someValuesFrom owl:Thing
] rdfs:subClassOf :ImpactAssessment .


###  http://example.com/secuman/ontology#HasImpactOnSafetyDomain
#:HasImpactOnSafetyDomain a owl:Class .
#    rdfs:label "Has impact on safety domain" ;
#    rdfs:comment "Has impact on safety domain: auxiliary class to define domain of has impact on safety" .
#:SecDA rdfs:subClassOf :HasImpactOnSafetyDomain .
#:Impact      rdfs:subClassOf :HasImpactOnSafetyDomain .





### Context


###  http://example.com/secuman/ontology#ContextSpecificThreat
:ContextSpecificThreat rdf:type owl:Class ;
    rdfs:label "Context specific threat" ;
    rdfs:comment "Context specific threat: operating environment, product, attack type, protection goal" .

[ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                            owl:onProperty :hasOperatingEnvironment;
                            owl:someValuesFrom owl:Thing
                        ]
                        [ rdf:type owl:Restriction ;
                            owl:onProperty :hasProduct;
                            owl:someValuesFrom owl:Thing
                        ]
                        [ rdf:type owl:Restriction ;
                            owl:onProperty :hasAttackType;
                            owl:someValuesFrom owl:Thing
                        ]
                        [ rdf:type owl:Restriction ;
                            owl:onProperty :hasProtectionGoal;
                            owl:someValuesFrom owl:Thing
                        ] ) ;
] rdfs:subClassOf :ContextSpecificThreat.

###  http://example.com/secuman/ontology#OperatingEnvironment
:OperatingEnvironment rdf:type owl:Class ;
    rdfs:label "Operating environment" ;
    rdfs:comment "Operating environment: physical, network, system and platform (/hardening)" .

[ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                            owl:onProperty :hasPhysicalSecurity;
                            owl:someValuesFrom owl:Thing
                        ]
                        [ rdf:type owl:Restriction ;
                            owl:onProperty :hasNetworkSecurity;
                            owl:someValuesFrom owl:Thing
                        ]
                        [ rdf:type owl:Restriction ;
                            owl:onProperty :hasSystemAndPlatformSecurity;
                            owl:someValuesFrom owl:Thing
                        ] ) ;
] rdfs:subClassOf :OperatingEnvironment.


###  http://example.com/secuman/ontology#Product
:Product rdf:type owl:Class ;
    rdfs:label "Product" ;
    rdfs:comment "Product: identity and access management, data security and privacy, operations and maintenance" .

[ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                            owl:onProperty :hasIdentityAndAccessManagement;
                            owl:someValuesFrom owl:Thing
                        ]
                        [ rdf:type owl:Restriction ;
                            owl:onProperty :hasDataSecurityAndPrivacy;
                            owl:someValuesFrom owl:Thing
                        ]
                        [ rdf:type owl:Restriction ;
                            owl:onProperty :hasOperationsAndMaintenance;
                            owl:someValuesFrom owl:Thing
                        ] ) ;
] rdfs:subClassOf :Product.






### Assessment

###  http://example.com/secuman/ontology#AnalyzedSecurityRisk
:AnalyzedSecurityRisk rdf:type owl:Class ;
    rdfs:label "Analyzed security risk" ;
    rdfs:comment "Analyzed security risk: context specific threat, impact, initial security risk level, component, asset" .

[ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                            owl:onProperty :hasContextSpecificThreat;
                            owl:someValuesFrom owl:Thing
                        ]
                        [ rdf:type owl:Restriction ;
                            owl:onProperty :hasImpact;
                            owl:someValuesFrom owl:Thing
                        ]
                        [ rdf:type owl:Restriction ;
                            owl:onProperty :hasInitialSecurityRiskLevel;
                            owl:someValuesFrom owl:Thing
                        ]
                        [ rdf:type owl:Restriction ;
                            owl:onProperty :hasComponent;
                            owl:someValuesFrom owl:Thing
                        ]
                        [ rdf:type owl:Restriction ;
                            owl:onProperty :hasAsset;
                            owl:someValuesFrom owl:Thing
                        ] ) ;
] rdfs:subClassOf :AnalyzedSecurityRisk.



### Control

###  http://example.com/secuman/ontology#ControlledSecurityRisk
:ControlledSecurityRisk rdf:type owl:Class ;
    rdfs:label "Controlled security risk" ;
    rdfs:comment "Controlled security risk: analyzed security risk, residual security risk level, secda" .

[ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                            owl:onProperty :hasAnalyzedSecurityRisk;
                            owl:someValuesFrom owl:Thing
                        ]
                        [ rdf:type owl:Restriction ;
                            owl:onProperty :hasResidualSecurityRiskLevel;
                            owl:someValuesFrom owl:Thing
                        ]
                        [ rdf:type owl:Restriction ;
                            owl:onProperty :isMitigatedBy;
                            owl:someValuesFrom owl:Thing
                        ] ) ;
] rdfs:subClassOf :ControlledSecurityRisk.


