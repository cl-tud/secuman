@prefix : <http://example.com/secuman/ontology#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ns: <http://purl.org/ontology/bibo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix vann: <http://purl.org/vocab/vann/> .
#@prefix riskman: <https://w3id.org/riskman/ontology#> .  
@base <http://example.com/secuman/ontology#> .

<http://example.com/secuman/ontology#> 
                                      rdf:type owl:Ontology ;
                                      owl:versionIRI <http://example.com/secuman/ontology#/0.0.0> ; 
                                      dcterms:description "The Secuman Ontology defines various notions related to risk management of security aspects of medical devices." ;
                                      dcterms:abstract "The Secuman Ontology defines various notions related to risk management of security aspects of medical devices. " ;
                                      schema:funder "(Add funder info)" ;
                                      schema:funding "(Add funding info)" ;
                                      dcterms:license <http://creativecommons.org/licenses/by/4.0/> ;
                                      dcterms:title "Digital Security Risk Management Ontology" ; 
                                      dcterms:created "2025-08-20"^^xsd:date ;
   #                                   dcterms:issued "2025-08-20"^^xsd:date ;
    #                                  ns:status "Published" ;
   #                                   dcterms:source <https://w3id.org/secuman/repo/> ;
    #                                  schema:citation "" ;
 #                                     schema:logo <https://raw.githubusercontent.com/cl-tud/secuman/refs/heads/main/assets/secuman_green.png> ;
                                      owl:versionInfo "0.0.0" ;
                                      rdfs:label "The Secuman Ontology" ;
#                                      rdfs:seeAlso <https://w3id.org/secuman/> ;
                                      schema:dateModified "2026-03-06"^^xsd:date ;
                                      vann:preferredNamespacePrefix "secuman"  ;
                                      vann:preferredNamespaceURI <http://example.com/secuman/ontology#> ;
                                        dcterms:creator  _:person_diller, _:person_strass ;
                                       dcterms:author  _:person_diller,  _:person_strass ;
                                      dcterms:contributor _:person_esslinger, _:person_hartig, _:person_heidenreich, _:person_mehr  . 

# Named blank nodes for creators/authors

_:person_diller
    a schema:Person ;
    schema:name "Martin Diller" ;
    schema:url <https://iccl.inf.tu-dresden.de/web/Martin_Diller/en> ;
    schema:affiliation _:iccl_tud .

_:person_strass
    a schema:Person ;
    schema:name "Hannes Straß" ;
    schema:url <https://iccl.inf.tu-dresden.de/web/Hannes_Stra%C3%9F/en> ;
    schema:affiliation _:iccl_tud .

_:person_hartig
    a schema:Person ;
    schema:name "Evi Hartig" ;
    schema:affiliation _:ekfz .

_:person_esslinger
    a schema:Person ;
    schema:name "Anne Eßlinger" ;
    schema:affiliation _:ekfz .

_:person_heidenreich
    a schema:Person ;
    schema:name "Georg Heidenreich" ;
    schema:affiliation _:siemens_healthineers .

_:person_mehr
    a schema:Person ;
    schema:name "Lia Mehr" ;
    schema:affiliation _:secunet .



# Organizations
_:iccl_tud
    a schema:Organization ;
    schema:name "ICCL, TU Dresden" ;
    schema:url <https://iccl.inf.tu-dresden.de/web/International_Center_for_Computational_Logic> .

_:ekfz
    a schema:Organization ;
    schema:name "EKFZ, TU Dresden" .

_:siemens_healthineers
    a schema:Organization ;
    schema:name "Siemens Healthineers" .

_:secunet
    a schema:Organization ;
    schema:name "Secunet AG" .


################################################################
#    Object and Datatype Properties
#################################################################

### General

###  http://example.com/secuman/ontology#hasAttackerProfile
:hasAttackerProfile rdf:type owl:ObjectProperty ;
            rdfs:domain :LikelihoodFactor ;
            rdfs:range :AttackerProfile ;
            rdfs:comment "Links a likelihood factor to its attacker profile." ;
            rdfs:label "has attacker profile" .



###  http://example.com/secuman/ontology#hasImpactLevel
:hasImpactLevel rdf:type owl:ObjectProperty ;
            rdfs:domain :SecurityRiskLevel ;
            rdfs:range :ImpactLevel ;
            rdfs:comment "Links a security risk level to its impact level." ;
            rdfs:label "has impact level" .

###  http://example.com/secuman/ontology#hasLikelihoodFactor
:hasLikelihoodFactor rdf:type owl:ObjectProperty ;
            rdfs:domain :SecurityRiskLevel ;
            rdfs:range :LikelihoodFactor ;
            rdfs:comment "Links a security risk level to its likelihood factor." ;
            rdfs:label "has likelihood factor" .


###  http://example.com/secuman/ontology#hasRationale
:hasRationale rdf:type owl:ObjectProperty ;
            rdfs:domain :ImpactAssessment ;
            rdfs:range :Rationale ;
            rdfs:comment "Links an impact assessment to its rationale." ;
            rdfs:label "has rationale" .


###  http://example.com/secuman/ontology#hasSafetyImpactAssessment
:hasSafetyImpactAssessment rdf:type owl:ObjectProperty ;
            rdfs:domain :ImpactAssessmentDomain ;
            rdfs:range :ImpactAssessment ;
            rdfs:comment "Links an impact assessment domain (impact or SecDA) to its safety impact assessment." ;
            rdfs:label "has safety impact assessment" .


###  http://example.com/secuman/ontology#hasSecurityImpactAssessment
:hasSecurityImpactAssessment rdf:type owl:ObjectProperty ;
            rdfs:domain :ImpactAssessmentDomain ;
            rdfs:range :ImpactAssessment ;
            rdfs:comment "Links an impact assessment domain (impact or SecDA) to its security impact assessment." ;
            rdfs:label "has security impact assessment" .



###  http://example.com/secuman/ontology#hasSecurityRiskLevel
:hasSecurityRiskLevel rdf:type owl:ObjectProperty ;
            rdfs:domain :SecurityRisk ;
            rdfs:range :SecurityRiskLevel ;
            rdfs:comment "Links a security risk to its security risk level." ;
            rdfs:label "has security risk level" .



###  http://example.com/secuman/ontology#hasVulnerabilityLevel
:hasVulnerabilityLevel rdf:type owl:ObjectProperty ;
            rdfs:domain :LikelihoodFactor ;
            rdfs:range :VulnerabilityLevel ;
            rdfs:comment "Links a likelihood factor to its vulnerability level." ;
            rdfs:label "has vulnerabiility level" .


###  http://example.com/secuman/ontology#isAffected
:isAffected rdf:type owl:DatatypeProperty ;
            rdfs:domain :ImpactAssessment ;
            rdfs:range xsd:boolean ;
            rdfs:comment "Indicates whether the aspect under consideration (e.g., safety, security) is affected." ;
            rdfs:label "is affected" .


### Context

###  http://example.com/secuman/ontology#hasAttackType
:hasAttackType rdf:type owl:ObjectProperty ;
            rdfs:domain :ContextSpecificThreat ;
            rdfs:range :AttackType ;
            rdfs:comment "Links a context specific threat to its attack type." ;
            rdfs:label "has attack type" .

###  http://example.com/secuman/ontology#hasDataSecurityAndPrivacy
:hasDataSecurityAndPrivacy rdf:type owl:ObjectProperty ;
            rdfs:domain :Product ;
            rdfs:range :DataSecurityAndPrivacy ;
            rdfs:comment "Links a product to its data security and privacy." ;
            rdfs:label "has data security and privacy" .


###  http://example.com/secuman/ontology#hasIdentityAndAccessManagement
:hasIdentityAndAccessManagement rdf:type owl:ObjectProperty ;
            rdfs:domain :Product ;
            rdfs:range :IdentityAndAccessManagement ;
            rdfs:comment "Links a product to its identity and access management." ;
            rdfs:label "has identity and access management" .

###  http://example.com/secuman/ontology#hasOperationsAndMaintenance
:hasOperationsAndMaintenance rdf:type owl:ObjectProperty ;
            rdfs:domain :Product ;
            rdfs:range :OperationsAndMaintenance ;
            rdfs:comment "Links a product to its operations and maintenance." ;
            rdfs:label "has operations and maintenance" .




###  http://example.com/secuman/ontology#hasNetworkSecurity
:hasNetworkSecurity rdf:type owl:ObjectProperty ;
            rdfs:domain :OperatingEnvironment ;
            rdfs:range :NetworkSecurity ;
            rdfs:comment "Links an operating environment to its network security." ;
            rdfs:label "has network security" .

###  http://example.com/secuman/ontology#hasOperatingEnvironment
:hasOperatingEnvironment rdf:type owl:ObjectProperty ;
            rdfs:domain :ContextSpecificThreat ;
            rdfs:range :OperatingEnvironment ;
            rdfs:comment "Links a context specific threat to its operating environment." ;
            rdfs:label "has operating environment" .

###  http://example.com/secuman/ontology#hasPhysicalSecurity
:hasPhysicalSecurity rdf:type owl:ObjectProperty ;
            rdfs:domain :OperatingEnvironment ;
            rdfs:range :PhysicalSecurity ;
            rdfs:comment "Links an operating environment to its physical security." ;
            rdfs:label "has physical security" .

###  http://example.com/secuman/ontology#hasProduct
:hasProduct rdf:type owl:ObjectProperty ;
            rdfs:domain :ContextSpecificThreat ;
            rdfs:range :Product ;
            rdfs:comment "Links a context specific threat to its product." ;
            rdfs:label "has product" .

###  http://example.com/secuman/ontology#hasProtectionGoal
:hasProtectionGoal rdf:type owl:ObjectProperty ;
            rdfs:domain :ContextSpecificThreat ;
            rdfs:range :ProtectionGoal ;
            rdfs:comment "Links a context specific threat to its protection goal." ;
            rdfs:label "has protection goal" .



###  http://example.com/secuman/ontology#hasSystemAndPlatformSecurity
:hasSystemAndPlatformSecurity rdf:type owl:ObjectProperty ;
            rdfs:domain :OperatingEnvironment ;
            rdfs:range :SystemAndPlatformSecurity ;
            rdfs:comment "Links an operating environment to its system and platform security." ;
            rdfs:label "has system and platform security" .









### Assessment

###  http://example.com/secuman/ontology#hasAsset
:hasAsset rdf:type owl:ObjectProperty ;
            rdfs:domain :AnalyzedSecurityRisk ;
            rdfs:range :Asset ;
            rdfs:comment "Links an analyzed security risk to its asset." ;
            rdfs:label "has asset" .

###  http://example.com/secuman/ontology#hasComponent
:hasComponent rdf:type owl:ObjectProperty ;
            rdfs:domain :AnalyzedSecurityRisk ;
            rdfs:range :Component ;
            rdfs:comment "Links an analyzed security risk to its component." ;
            rdfs:label "has component" .


###  http://example.com/secuman/ontology#hasContextSpecificThreat
:hasContextSpecificThreat rdf:type owl:ObjectProperty ;
            rdfs:domain :AnalyzedSecurityRisk ;
            rdfs:range :ContextSpecificThreat ;
            rdfs:comment "Links an analyzed security risk to its context specific threat." ;
            rdfs:label "has context specific threat" .

###  http://example.com/secuman/ontology#hasImpact
:hasImpact rdf:type owl:ObjectProperty ;
            rdfs:domain :AnalyzedSecurityRisk ;
            rdfs:range :Impact ;
            rdfs:comment "Links an analyzed security risk to its impact." ;
            rdfs:label "has impact" .



###  http://example.com/secuman/ontology#hasInitialSecurityRiskLevel
:hasInitialSecurityRiskLevel rdf:type owl:ObjectProperty ;
            rdfs:domain :AnalyzedSecurityRisk ;
            rdfs:range :SecurityRiskLevel ;
            #Note: contained in hasSecurityRiskLevel
            rdfs:subPropertyOf :hasSecurityRiskLevel ;
            rdfs:comment "Links an analyzed security risk to its initial security risk level." ;
            rdfs:label "has initial security risk level" .







### Control 

###  http://example.com/secuman/ontology#hasAnalyzedSecurityRisk
:hasAnalyzedSecurityRisk rdf:type owl:ObjectProperty ;
            rdfs:domain :ControlledSecurityRisk ;
            rdfs:range :AnalyzedSecurityRisk ;
            rdfs:comment "Links a controlled security risk to its analyzed security risk." ;
            rdfs:label "has analyzed security risk" .

###  http://example.com/secuman/ontology#hasResidualSecurityRiskLevel
:hasResidualSecurityRiskLevel rdf:type owl:ObjectProperty ;
            rdfs:domain :ControlledSecurityRisk ;
            rdfs:range :SecurityRiskLevel ;
            #Note: contained in hasSecurityRiskLevel
            rdfs:subPropertyOf :hasSecurityRiskLevel ;
            rdfs:comment "Links a controlled security risk to its residual security risk level." ;
            rdfs:label "has residual security risk level" .



###  http://example.com/secuman/ontology#isMitigatedBy
:isMitigatedBy rdf:type owl:ObjectProperty ;
            rdfs:domain :ControlledSecurityRisk ;
            rdfs:range :SecDA ;
            rdfs:comment "Links a controlled security risk to its secure design argument." ;
            rdfs:label "is mitigated by" .


### SecDAs

###  http://example.com/secuman/ontology#hasAssumption
:hasAssumption rdf:type owl:ObjectProperty ;
            rdfs:domain :SecDA ;
            rdfs:range :Assumption ;
            rdfs:comment "Links a SecDA to its assumption." ;
            rdfs:label "has assumption" .

###  http://example.com/secuman/ontology#hasAssurance
:hasAssurance rdf:type owl:ObjectProperty ;
            rdfs:domain :SecDA ;
            rdfs:range :Assurance ;
            rdfs:comment "Links a SecDA to its assurance." ;
            rdfs:label "has assurance" .


###  http://example.com/secuman/ontology#hasInterventionMethod
:hasInterventionMethod rdf:type owl:ObjectProperty ;
            rdfs:domain :SecDA ;
            rdfs:range :InterventionMethod ;
            rdfs:comment "Links a SecDA to its intervention method." ;
            rdfs:label "has intervention method" .

###  http://example.com/secuman/ontology#hasImplementationManifest
:hasImplementationManifest rdf:type owl:ObjectProperty ;
            rdfs:domain :SecDA ;
            rdfs:range :ImplementationManifest ;
            rdfs:comment "Links a SecDA to its implementation manifest." ;
            rdfs:label "has implementation manifest" .        

###  http://example.com/secuman/ontology#hasLocationOfIntervention
:hasLocationOfIntervention rdf:type owl:ObjectProperty ;
            rdfs:domain :SecDA ;
            rdfs:range :LocationOfIntervention ;
            rdfs:comment "Links a SecDA to its location of intervention." ;
            rdfs:label "has location of intervention" .

###  http://example.com/secuman/ontology#hasOrganisationalContextOfIntervention
:hasOrganisationalContextOfIntervention rdf:type owl:ObjectProperty ;
            rdfs:domain :SecDA ;
            rdfs:range :OrganisationalContextOfIntervention ;
            rdfs:comment "Links a SecDA to its organisational context of intervention." ;
            rdfs:label "has organisational context of intervention" .


###  http://example.com/secuman/ontology#hasStrategy
:hasStrategy rdf:type owl:ObjectProperty ;
            rdfs:domain :SecDA ;
            rdfs:range :Strategy ;
            rdfs:comment "Links a SecDA to its strategy." ;
            rdfs:label "has strategy" .

###  http://example.com/secuman/ontology#hasSubSecDA
:hasSubSecDA rdf:type owl:ObjectProperty ;
            rdfs:domain :SecDA ;
            rdfs:range :SecDA ;
            rdfs:comment "Links a SecDA to its sub-SecDA." ;
            rdfs:label "has sub-SecDA" .


###  http://example.com/secuman/ontology#hasTestReport
:hasTestReport rdf:type owl:ObjectProperty ;
            rdfs:domain :SecDA ;
            rdfs:range :TestReport ;
            rdfs:comment "Links a SecDA to its test report." ;
            rdfs:label "has test report" .



