### http://example.com/secuman/ontology#SecurityFacet
# Auxilliary: Super-class capturing any of Strategy, InterventionMethod, ...
#:SecurityFacet rdf:type owl:Class .

#:Strategy               rdfs:subClassOf :SecurityFacet .
#:InterventionMethod     rdfs:subClassOf :SecurityFacet .
#:LocationOfIntervention rdfs:subClassOf :SecurityFacet .
#:OrganisationalContextOfIntervention  rdfs:subClassOf :SecurityFacet .
#:Assumption             rdfs:subClassOf :SecurityFacet .
#:ImpactOnSafety         rdfs:subClassOf :SecurityFacet .
#:TestReport             rdfs:subClassOf :SecurityFacet .


# Subproperties inherit domain/range automatically
#:hasStrategy             rdfs:subPropertyOf :hasSecurityFacet .
#:hasInterventionMethod   rdfs:subPropertyOf :hasSecurityFacet .
#:hasLocationOfIntervention   rdfs:subPropertyOf :hasSecurityFacet .
#:hasOrganisationalContextOfIntervention rdfs:subPropertyOf :hasSecurityFacet .
#:hasAssumption rdfs:subPropertyOf :hasSecurityFacet .
#:hasTestReport rdfs:subPropertyOf :hasSecurityFacet .
