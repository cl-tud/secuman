@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <http://schema.org/> .
@prefix secuman: <http://example.com/secuman/ontology#> .
#@prefix rlevel: <http://example.com/secuman/ontology#> .
@prefix : <http://example.com/secuman/shapes#> .


### General


:ImpactAssessmentShape
  a sh:NodeShape ;
  sh:targetClass secuman:ImpactAssessment ;
  sh:property [
    sh:path secuman:isAffected ;
    sh:message "Every impact assessment must have exactly one value (true or false) for is affected." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ],  [
    sh:path secuman:hasRationale ;
    sh:message "Every impact assessment must have at most one rationale." ;  
    sh:maxCount 1 ;
  ]
. 


:LikelihoodFactorShape
  a sh:NodeShape ;
  sh:targetClass secuman:LikelihoodFactor ;
  sh:property [
    sh:path secuman:hasAttackerProfile ;
    sh:message "Every likelihood factor must have exactly one attacker profile." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ],  [
    sh:path secuman:hasVulnerabilityLevel ;
    sh:message "Every likelihood factor must have exactly one vulnerability level." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ]
. 


:SecurityRiskShape
  a sh:NodeShape ;
  sh:targetClass secuman:SecurityRisk ;
  sh:property [
    sh:path secuman:hasSecurityRiskLevel ;
    sh:message "Every security risk must have exactly one security risk level." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ]
. 

:SecurityRiskLevelShape
  a sh:NodeShape ;
  sh:targetClass secuman:SecurityRiskLevel ;
  sh:property [
    sh:path secuman:hasImpactLevel ;
    sh:message "Every security risk level must have exactly one impact level." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ],  [
    sh:path secuman:hasLikelihoodFactor ;
    sh:message "Every security risk level must have exactly one likelihood factor." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ]
. 




### Context

:ContextSpecificThreatShape
  a sh:NodeShape ;
  sh:targetClass secuman:ContextSpecificThreat ;
  sh:property [
    sh:path secuman:hasOperatingEnvironment ;
    sh:message "Every context specific threat must have exactly one operating environment." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ], [
    sh:path secuman:hasProduct ;
    sh:message "Every context specific threat must have exactly one product." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ], [
    sh:path secuman:hasAttackType ;
    sh:message "Every context specific threat must have exactly one attack type." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ], [
    sh:path secuman:hasProtectionGoal ;
    sh:message "Every context specific threat must have exactly one protection goal." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] 
. 


:OperatingEnvironmentShape
  a sh:NodeShape ;
  sh:targetClass secuman:OperatingEnvironment ;
  sh:property [
    sh:path secuman:hasPhysicalSecurity ;
    sh:message "Every operating environment must have exactly one physical security." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ], [
    sh:path secuman:hasNetworkSecurity ;
    sh:message "Every operating environment must have exactly one network security." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ], [
    sh:path secuman:hasSystemAndPlatformSecurity ;
    sh:message "Every operating environment must have exactly one system and platform security." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ]
. 

:ProductShape
  a sh:NodeShape ;
  sh:targetClass secuman:Product ;
  sh:property [
    sh:path secuman:hasIdentityAndAccessManagement ;
    sh:message "Every product must have exactly one identity and access management." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ], [
    sh:path secuman:hasDataSecurityAndPrivacy ;
    sh:message "Every product must have exactly one data security and privacy." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ], [
    sh:path secuman:hasOperationsAndMaintenance ;
    sh:message "Every product must have exactly one operations and maintenance." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ]
. 

#Note: may not work for all validators, could also rather verify in ContextSpecificThreat shape

:ProtectionGoalShape
    a sh:NodeShape ;
    sh:targetClass secuman:ProtectionGoal ;
    sh:in ( secuman:Availability secuman:Confidentiality secuman:Integrity ) ;
    sh:message "A protection goal must be one of availability, confidentiality, or integrity" .


### Assessment


:AnalyzedSecurityRiskShape
  a sh:NodeShape ;
  sh:targetClass secuman:AnalyzedSecurityRisk ;
  sh:property [
    sh:path secuman:hasContextSpecificThreat ;
    sh:message "Every analyzed security risk must have exactly one context specific threat." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ], [
    sh:path secuman:hasImpact ;
    sh:message "Every analyzed security risk must have at least one impact." ;  
    sh:minCount 1 ;
  ], [
    sh:path secuman:hasInitialSecurityRiskLevel ;
    sh:message "Every analyzed security risk must have exactly one initial security risk level." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ],  [
    sh:path secuman:hasComponent ;
    sh:message "Every analyzed security risk must have exactly one component." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ], [
    sh:path secuman:hasAsset ;
    sh:message "Every analyzed security risk must have at least one asset." ;  
    sh:minCount 1 ;
  ]
. 

### Control


  :ControlledSecurityRiskShape
  a sh:NodeShape ;
  sh:targetClass secuman:ControlledSecurityRisk ;
  sh:property [
    sh:path secuman:hasAnalyzedSecurityRisk ;
    sh:message "Every controlled security risk must have exactly one analyzed security risk." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ],  [
    sh:path secuman:hasResidualSecurityRiskLevel ;
    sh:message "Every controlled security risk must have exactly one residual security risk level." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ],  [
    sh:path secuman:isMitigatedBy ;
    sh:message "Every controlled security risk must have exactly one secure design argument." ;  
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ]
. 

### SDAs

:AssuranceSecDAShape
  a sh:NodeShape ;
  sh:targetClass secuman:AssuranceSecDA ;
  sh:property [ 
      sh:path secuman:hasAssurance ;
      sh:message "Every assurance SecDA must have exactly one assurance." ;  
      sh:minCount 1 ;
      sh:maxCount 1 ;
  ], [
      sh:path secuman:hasSubSecDA  ;
      sh:message "SubSecDAs of an AssuranceSecDA must again be AssuranceSecDAs." ;
      sh:class secuman:AssuranceSecDA ;
  ]
.


:SecDAShape
  a sh:NodeShape ;
  sh:targetClass secuman:SecDA ;

  # Unconditional cardinalities
  sh:property [
    sh:path secuman:hasStrategy ;
    sh:message "Every SecDA must have exactly one strategy." ;
    sh:minCount 1 ; sh:maxCount 1 ;
  ] ;
 # sh:property [ sh:path secuman:hasInterventionMethod ; sh:maxCount 1 ] ;
 # sh:property [ sh:path secuman:hasOrganisationalContextOfIntervention ; sh:maxCount 1 ] ;
  sh:property [ 
    sh:path secuman:hasLocationOfIntervention ;
    sh:message "Every SecDA can have at most one location of intervention." ; 
    sh:maxCount 1 ] ;
  sh:property [ 
    sh:path secuman:hasAssumption ;
    sh:message "Every SecDA can have at most one assumption." ;  
    sh:maxCount 1 ] ;
  sh:property [ 
    sh:path secuman:hasSafetyImpactAssessment ;
    sh:message "Every SecDA must have exactly one safety impact assessment." ;  
    sh:minCount 1 ; sh:maxCount 1 ] ;
  sh:property [ 
    sh:path secuman:hasSecurityImpactAssessment ;
    sh:message "Every SecDA must have exactly one security impact assessment." ;  
    sh:minCount 1 ; sh:maxCount 1 ] ;
  sh:property [ 
    sh:path secuman:hasImplementationManifest ;
    sh:message "Every SecDA can have at most one implementation manifest." ;  
    sh:maxCount 1 ] ;
  sh:property [ 
    sh:path secuman:hasAssurance ;
    sh:message "Every SecDA can have at most one assurance." ;  
    sh:maxCount 1 ] ;

  # ∃ hasSubSecDA*.SecDAI
  sh:property [
    sh:path [ sh:zeroOrMorePath secuman:hasSubSecDA ] ;
    sh:qualifiedValueShape [ sh:class secuman:SecDAI ] ;
    sh:qualifiedMinCount 1 ;
    sh:message "Every SecDA needs a final mitigation (which has the Implementation Manifest)." ;
  ] ;

  # (≤0 hasSubSecDA−) ⇒ (=1 hasTestReport)
  sh:or ( :NotTopSecDA  :TopSecDAAndOneTestReport ) ;
  sh:message "A SecDA must either not be a top SecDA, or, if it is a top SecDA, it must have exactly one test report." ;  

  # (≥1 hasSubSecDA−) ⇒ (≤0 hasTestReport)
  sh:or ( :TopSecDA  :NotTopSecDAAndNoTestReport ) ;
  sh:message "A SecDA that is not a top SecDA must not have a test report." ;

  sh:or ( :NotLeafSecDA  :LeafSecDAAndOneInterventionMethod ) ;
  sh:message "A leaf SecDA must have exactly one intervention method." ;
  
  sh:or ( :LeafSecDA  :NotLeafSecDAAndNoInterventionMethod ) ;
  sh:message "A non-leaf SecDA must not have an intervention method." ;
  
  sh:or ( :NotLeafSecDA  :LeafSecDAAndOneOrganisationalContextOfIntervention ) ;
  sh:message "A leaf SecDA must have exactly one organisational context of intervention." ;
  
  sh:or ( :LeafSecDA  :NotLeafSecDAAndNoOrganisationalContextOfIntervention ) ;
  sh:message "A non-leaf SecDA must not have an organisational context of intervention." ;

  sh:or ( :LeafSecDA  :NotLeafSecDAAndNoLocationOfIntervention ) ;
  sh:message "A non-leaf SecDA must not have a location of intervention." ;

  sh:or ( :LeafSecDA  :NotLeafSecDAAndNoAssumption ) ;  
  sh:message "A non-leaf SecDA must not have an assumption." ;


.

# Helper shapes 

# ≥1 hasSubSecDA−.⊤
:NotTopSecDA
  a sh:NodeShape ;
  sh:property [
    sh:path [ sh:inversePath secuman:hasSubSecDA ] ;
    sh:minCount 1 ;
  ] .

# Negation of incoming condition: ≤0 hasSubSecDA−.⊤
:TopSecDA
  a sh:NodeShape ;
  sh:property [
    sh:path [ sh:inversePath secuman:hasSubSecDA ] ;
    sh:maxCount 0 ;
  ] .

:LeafSecDA
  a sh:NodeShape ;
  sh:property [
    sh:path secuman:hasSubSecDA ;
    sh:maxCount 0 ;
  ] .

:NotLeafSecDA
  a sh:NodeShape ;
  sh:property [
    sh:path secuman:hasSubSecDA ;
    sh:minCount 1 ;
  ] .


:TopSecDAAndOneTestReport
  a sh:NodeShape ;
  sh:property [
    sh:path [ sh:inversePath secuman:hasSubSecDA ] ;
    sh:maxCount 0 ;
  ] ;
  sh:property [
    sh:path secuman:hasTestReport ;
    sh:minCount 1 ; sh:maxCount 1 ;
  #  sh:message "If the SecDA is a top SecDA, there must be exactly one test report." ;
  ] .

:NotTopSecDAAndNoTestReport
  a sh:NodeShape ;
  sh:property [
    sh:path [ sh:inversePath secuman:hasSubSecDA ] ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path secuman:hasTestReport ;
    sh:maxCount 0 ;
   # sh:message "If the SecDA is not a top SecDA, there must be no test report." ;
  ] .

:LeafSecDAAndOneInterventionMethod
  a sh:NodeShape ;
  sh:property [
    sh:path secuman:hasSubSecDA ;
    sh:maxCount 0 ;
  ] ;
  sh:property [
    sh:path secuman:hasInterventionMethod ;
    sh:minCount 1 ; sh:maxCount 1 ;
   # sh:message "If the SecDA is a leaf SecDA, there must be one intervention method." ;
  ] .

:NotLeafSecDAAndNoInterventionMethod
  a sh:NodeShape ;
  sh:property [
    sh:path secuman:hasSubSecDA ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path secuman:hasInterventionMethod ;
    sh:maxCount 0 ;
  #  sh:message "If the SecDA is not a leaf SecDA, there must be no intervention method." ;
  ] .

:LeafSecDAAndOneOrganisationalContextOfIntervention
  a sh:NodeShape ;
  sh:property [
    sh:path secuman:hasSubSecDA ;
    sh:maxCount 0 ;
  ] ;
  sh:property [
    sh:path secuman:hasOrganisationalContextOfIntervention ;
    sh:minCount 1 ; sh:maxCount 1 ;
  #  sh:message "If the SecDA is a leaf SecDA, there must be one organisational context of intervention." ;
  ] .

:NotLeafSecDAAndNoOrganisationalContextOfIntervention
  a sh:NodeShape ;
  sh:property [
    sh:path secuman:hasSubSecDA ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path secuman:hasOrganisationalContextOfIntervention ;
    sh:maxCount 0 ;
  #  sh:message "If the SecDA is not a leaf SecDA, there must be no organisational context of intervention." ;
  ] .

:NotLeafSecDAAndNoLocationOfIntervention
  a sh:NodeShape ;
  sh:property [
    sh:path secuman:hasSubSecDA ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path secuman:hasLocationOfIntervention ;
    sh:maxCount 0 ;
 #   sh:message "If the SecDA is not a leaf SecDA, there must be no location of intervention." ;
  ] .

:NotLeafSecDAAndNoAssumption
  a sh:NodeShape ;
  sh:property [
    sh:path secuman:hasSubSecDA ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path secuman:hasAssumption ;
    sh:maxCount 0 ;
  #  sh:message "If the SecDA is not a leaf SecDA, there must be no assumption." ;
  ] .